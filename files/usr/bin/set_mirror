#!/bin/sh


createMonitor $1 $2 $3

function createMonitor {


	monitor_iface=$1
	monitor_vlan=$2
	monitor_outbound=$3

	tc qdisc add dev $monitor_iface handle ffff: ingress
	tc filter add dev $monitor_iface parent ffff: protocol all u32 match u32 0 0 action mirred egress mirror dev $monitor_vlan

	if [ "$monitor_outbound" ];
	then
		tc qdisc add dev $monitor_iface root handle 1: htb
		tc filter add dev $monitor_iface parent 1: protocol all u32 match u32 0 0 action mirred egress mirror dev $monitor_vlan
	fi

}

exit 0

