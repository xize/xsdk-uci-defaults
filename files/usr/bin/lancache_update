#!/bin/sh

if [[ $# -eq 0 ]];
then
        echo "modifies dnsmasq instance 'lancache' with the latest listings from cache-domains"
        echo ""
        echo "requirements: bash, git-http, jq"
        echo 'usage: lancache ip (sets the ip of lancache, and downloads latest cache-domains...)'
        exit 0
fi

if [ "$(uci -q get dhcp.lancache)" ];
then
        cd /tmp

        if [ -d 'cache-domains' ]; then
                rm -rf cache-domains
        fi
        echo "cloning github.com/uklans/cache-domains to /tmp/cache-domains"
        git clone --quiet https://github.com/uklans/cache-domains
        echo "cloning done."
        cd cache-domains/scripts

echo "dropping config, in cache-domains appending the ip from argument as value."
cat << EO > config.json
{
  "combined_output": true,
  "ips": {
    "steam": "$1",
    "origin": "$1",
    "blizzard": "$1",
    "windows": "$1",
    "riot": "$1",
    "generic": "$1"
  },
  "cache_domains": {
    "default": "generic",
    "blizzard": "blizzard",
    "origin": "origin",
    "riot": "riot",
    "steam": "steam",
    "wsus": "windows",
    "xboxlive": "windows"
  }
}
EO

        echo "launching create-dnsmasq"
        bash create-dnsmasq.sh > /dev/null
        echo "done create-dnsmasq"
        cd output/dnsmasq
        echo "sanitizing dnsmasq config to work with uci."
        cat lancache.conf | grep -o '^[^#]*' | sed 's/address\=//' | grep -vwE "local=" > /tmp/lancache.uci

        IN=$(cat /tmp/lancache.uci)


        if [ "$(uci -q get dhcp.lancache.address)" ];
        then
                uci del dhcp.lancache.address
        fi

        for x in $IN
        do
                #echo "address: $x"
                uci add_list dhcp.lancache.address="$x"
        done

        uci commit dhcp

        echo "uci command saved for dhcp."

        echo "cleaning up ;-)"
        cd /tmp
        rm -rf cache-domains
        rm -rf lancache.uci
fi

exit 0

