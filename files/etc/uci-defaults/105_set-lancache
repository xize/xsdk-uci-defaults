#!/bin/sh

if [ "$(uci -q get xsdk.@factory[0].init)" != "1" ]; then

	uci set dhcp.lancache=dnsmasq
	uci set dhcp.lancache.ignore='1'
	uci set dhcp.lancache.rebind_protection='0'
	uci set dhcp.lancache.localservice='0'
	uci set dhcp.lancache.port='7853'
	uci set dhcp.lancache.noresolv='1'
	uci add_list dhcp.lancache.server='127.0.0.1#5342'
	uci add firewall rule
	uci set firewall.@rule[-1].name='allow-lancache-from-any'
	uci set firewall.@rule[-1].src='*'
	uci set firewall.@rule[-1].dest='proxmox'
	uci set firewall.@rule[-1].dest_port='80 443 53'
	uci set firewall.@rule[-1].dest_ip='10.244.244.5'

	uci add firewall redirect
	uci set firewall.@redirect[-1].name='allow-pcnet-lancache'
	uci set firewall.@redirect[-1].src='pcnet'
	uci set firewall.@redirect[-1].src_dport='53'
	uci set firewall.@redirect[-1].dest_port='7865'
	uci set firewall.@redirect[-1].target='DNAT'

	uci add firewall redirect
        uci set firewall.@redirect[-1].name='allow-aya-lancache'
        uci set firewall.@redirect[-1].src='ayaneo'
        uci set firewall.@redirect[-1].src_dport='53'
        uci set firewall.@redirect[-1].dest_port='7865'
        uci set firewall.@redirect[-1].target='DNAT'

        uci add firewall redirect
        uci set firewall.@redirect[-1].name='allow-ps5-lancache'
        uci set firewall.@redirect[-1].src='ps5'
        uci set firewall.@redirect[-1].src_dport='53'
        uci set firewall.@redirect[-1].dest_port='7865'
        uci set firewall.@redirect[-1].target='DNAT'

	uci commit firewall
	uci commit dhcp
fi

exit 0

